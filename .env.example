SENTERO_DEV_MODE=true
SENTERO_SENSOR_SOURCE=homeassistant

# Development only: Home Assistant adapter
HA_URL=http://homeassistant.local:8123
HA_TOKEN=replace-me

# Production: Mosquitto/Zigbee2MQTT/ESP32 sensors
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
ZIGBEE2MQTT_TOPIC_PREFIX=zigbee2mqtt

# Optional bootstrap for local MQTT adapter development
SENTERO_MQTT_BOOTSTRAP_EVENTS=

# Standalone update mechanism
SENTERO_UPDATE_CHANNEL=stable
SENTERO_UPDATE_MODE=dry_run
SENTERO_UPDATE_MANIFEST_URL=
SENTERO_UPDATE_MANIFEST_PATH=update-manifest.json
