SENTERO_DEV_MODE=false
SENTERO_SENSOR_SOURCE=homeassistant
LOG_LEVEL=INFO

# Development: Home Assistant sensor source
HA_URL=http://homeassistant.local:8123
HA_TOKEN=

# Production: Mosquitto/Zigbee2MQTT/ESP32 sensors
SENTERO_MQTT_HOST=localhost
SENTERO_MQTT_PORT=1883
SENTERO_MQTT_USERNAME=
SENTERO_MQTT_PASSWORD=
SENTERO_MQTT_TOPIC_PREFIX=sentero
SENTERO_ZIGBEE2MQTT_TOPIC_PREFIX=zigbee2mqtt
SENTERO_MQTT_SNAPSHOT_TIMEOUT=2.5

# Optional local test data for MQTT adapter development
SENTERO_MQTT_BOOTSTRAP_EVENTS=

# Standalone update mechanism
SENTERO_UPDATE_CHANNEL=stable
SENTERO_UPDATE_MODE=zip
UPDATE_BASE_URL=https://seirafi.de/robotersteve/sentero

# Optional LLM provider. Default keeps Sentero local/rule based.
SENTERO_LLM_PROVIDER=rule_based
OPENAI_API_KEY=
GEMINI_API_KEY=
CLAUDE_API_KEY=
ANTHROPIC_API_KEY=
